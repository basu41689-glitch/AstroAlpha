# ============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# IMPORTANT: Copy this file to .env and fill in your actual API keys
# NEVER commit .env to version control - it's in .gitignore
# See API_KEYS_SETUP.md for detailed instructions
# ============================================================================

# Frontend Environment Variables (Available in browser)
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_KEY=your-supabase-anon-key
VITE_OPENAI_API_KEY=sk-demo-placeholder
VITE_LLM_PROVIDER_API_KEY=demo-placeholder
# base URL used by the API client; leave blank for relative /api proxy in dev
VITE_API_BASE_URL=/api
VITE_DEBUG=false

# Backend Environment Variables (Server only - not exposed to browser)
OPENAI_API_KEY=sk-your-actual-openai-key
LLM_PROVIDER_API_KEY=your-actual-llm-key

# Server Configuration
NODE_ENV=development
PORT=3001
# comma-separated list of allowed origins for CORS
e.g. CORS_ORIGINS=http://localhost:5173,https://yourapp.com

# Environment Configuration for Options Analytics Engine

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server port
PORT=5000

# Node environment
NODE_ENV=development

# ============================================================================
# API KEYS & AUTHENTICATION
# ============================================================================

# OpenAI API Key (required for AI interpretation)
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk_your_openai_key_here

# NSE Gateway API Key (if using official NSE API)
# For production, integrate with Angel Broking, Firoz Broker, etc.
NSE_API_KEY=your_nse_api_key_here

# ============================================================================
# RISK-FREE RATE FOR BLACK-SCHOLES (Annual %)
# ============================================================================

# Default: 6% (Indian risk-free rate)
# Adjust based on current RBI rates
RISK_FREE_RATE=0.06

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# For Vercel deployment
# FRONTEND_URL=https://yourdomain.vercel.app

# ============================================================================
# LOGGING
# ============================================================================

# Log level: ERROR, WARN, INFO, DEBUG
LOG_LEVEL=INFO

# Enable file logging (creates logs in server/logs directory)
ENABLE_FILE_LOGGING=true

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# Option chain cache TTL in milliseconds (60 seconds)
MARKET_DATA_CACHE_TTL=60000

# Market data refresh interval (30 seconds)
MARKET_DATA_REFRESH_INTERVAL=30000

# ============================================================================
# DEPLOYMENT PLATFORMS
# ============================================================================

# For Render.com deployment
# Set environment variables in Render dashboard instead of .env file

# For Vercel (Frontend)
# Set REACT_APP_API_URL to your Render backend URL

# Example for production:
# FRONTEND_URL=https://options-engine.onrender.com
# REACT_APP_API_URL=https://options-engine.onrender.com
